# NTA GTFS-Realtime API key.
# Sign up at https://developer.nationaltransport.ie to get one (free).
NTA_API_KEY=your_api_key_here

# Databricks Community Edition credentials.
# Host is always https://community.cloud.databricks.com for CE.
# Token: Databricks UI → top-right menu → User Settings → Access tokens → Generate new token
DATABRICKS_HOST=https://community.cloud.databricks.com
DATABRICKS_TOKEN=your_databricks_token_here
