# NTA GTFS-Realtime API key — same one used by scripts/poc_fetch_gtfs.py
# and the Airflow ingest DAG. Sign up at https://developer.nationaltransport.ie
NTA_API_KEY=your_api_key_here

PORT=3000

# Optional overrides — usually left unset so these inherit the repo-root
# defaults from src/config.js.
# SCORING_DATA_DIR=/absolute/path/to/data
# LIVE_FEED_CACHE_MS=30000
