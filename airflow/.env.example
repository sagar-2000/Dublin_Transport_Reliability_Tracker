# docker-compose reads .env from this directory automatically.
# Copy this to airflow/.env and fill in your real values.

NTA_API_KEY=your_api_key_here

# Avoids file permission issues between the container and your host user.
# Run `id -u` on Linux/macOS and put the result here. If unsure, 50000
# (the default in the airflow image) works fine for local dev.
AIRFLOW_UID=50000
